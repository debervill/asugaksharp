<Window x:Class="asugaksharp.Features.Zasedanie.RaspisanieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Расписание заседаний ГЭК" Height="660" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтра -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Кафедра:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="ComboKafedra" Width="300"
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          VerticalContentAlignment="Center"/>
                <Button Content="Загрузить" Margin="8,0,4,0" Padding="14,4"
                        Click="BtnLoad_Click"/>
                <Button Content="Обновить" Padding="14,4"
                        Click="BtnRefresh_Click"/>
                <TextBlock x:Name="TextStatus" VerticalAlignment="Center"
                           Margin="16,0,0,0" Foreground="#666666" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Сетка расписания -->
        <DataGrid Grid.Row="1"
                  x:Name="DataGridSchedule"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionUnit="Cell"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  GridLinesVisibility="All"
                  HeadersVisibility="All"
                  RowHeight="55"
                  SelectedCellsChanged="DataGridSchedule_SelectedCellsChanged">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Панель редактирования -->
        <GroupBox Grid.Row="2" Header="Изменить дату заседания"
                  Margin="10,6,10,10" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0"
                         x:Name="ListSessions"
                         Height="65"
                         DisplayMemberPath="Label"
                         SelectionChanged="ListSessions_SelectionChanged"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,14,0">
                    <TextBlock Text="Новая дата:" FontSize="11" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DatePickerNew" IsEnabled="False" Width="150"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button x:Name="BtnSave" Content="Сохранить" Width="90"
                            IsEnabled="False" Margin="0,0,0,5"
                            Click="BtnSave_Click"/>
                    <Button Content="Отмена" Width="90"
                            Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
